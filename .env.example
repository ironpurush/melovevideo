# ============================================================
# Video Downloader — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://videodownloader.ironpurush.com
NEXT_PUBLIC_SITE_NAME=Video Downloader

# --- Google AdSense ---
# Replace with your Publisher ID from https://adsense.google.com
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX

# --- Google Analytics (optional) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Download Backend ---
# URL of your yt-dlp or similar backend microservice
# Example: https://api.yourbackend.com
DOWNLOAD_API_URL=http://localhost:3001
DOWNLOAD_API_SECRET=your-secret-key-here

# --- Rate Limiting (Redis for production) ---
# REDIS_URL=redis://localhost:6379

# --- Email / Contact Form ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# CONTACT_EMAIL=contact@videodownloader.com
